# 明察 provider 覆盖样例（§6.3 / §10）
#
# 用法：复制为 .crv/providers.yaml（装了 PyYAML）或 .crv/providers.json（零依赖），
# 放在你运行 mingcha 的工作目录下。这里的配置会**深合并**覆盖 config.py 的内置注册表，
# 让你无需改代码即可接新模型 / 换端点 / 调能力开关。
#
# ⚠ 密钥永远不写这里。密钥只走环境变量（api_key_env 指向的变量名）。
# 优先级：CLI --provider/--vision-model > 本文件 > config.py 默认。

providers:
  # 覆盖已有 provider 的某些字段（只写要改的，其余沿用内置默认）
  claude:
    base_url: https://api.anthropic.com      # 换回官方端点（默认走第三方代理）
    api_key_env: ANTHROPIC_API_KEY

  # 新增一个 OpenAI 兼容 provider = 加一段配置，不写代码
  myglm:
    kind: openai_compat
    base_url: https://open.bigmodel.cn/api/paas/v4
    api_key_env: ZHIPU_API_KEY
    caps:
      vision: true
      json_schema: true
      prompt_cache: false
      batch: false

# 角色 → provider:model（或 [provider, model]）。覆盖默认的画面/分类模型选择。
roles:
  vision: claude:claude-opus-4-8
  classify: claude:claude-haiku-4-5
